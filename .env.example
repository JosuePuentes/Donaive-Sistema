# ─── Base de Datos (PostgreSQL — no usar MongoDB) ─────────────
# Local:
DATABASE_URL="postgresql://postgres:password@localhost:5432/ferreteria_los_puentes?schema=public"
# Render: pegar "Internal Database URL" del PostgreSQL en el dashboard del Web Service (no subir al repo)

# ─── API (NestJS) ────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET="cambiar-por-secreto-seguro-en-produccion"
JWT_EXPIRES_IN="8h"
CORS_ORIGIN="http://localhost:3000"

# ─── Frontend (Next.js) ──────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001/api/v1"

# ─── Moneda Base del Sistema ─────────────────────────────────
BASE_CURRENCY="USD"
TRANSACTION_CURRENCY="VES"
